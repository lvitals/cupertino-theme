<?xml version="1.0"?>
<!DOCTYPE wallpapers SYSTEM "gnome-wp-list.dtd">
<wallpapers>
  <wallpaper deleted="false">
    <name>Cupertino</name>
    <filename>@full_datadir@/backgrounds/cupertino/cupertino-day.jpeg</filename>
    <filename-dark>@full_datadir@/backgrounds/cupertino/cupertino-night.jpeg</filename-dark>
    <options>zoom</options>
    <shade_type>solid</shade_type>
    <pcolor>#51a2da</pcolor>
    <scolor>#294172</scolor>
  </wallpaper>
</wallpapers>
